# Copy this file to .env and fill in your own values.
# Do NOT commit the real .env file.

# TMDb API (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key

# Google Cloud / BigQuery
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BQ_DATASET=Movies_Dataset
# Optional: path to a service account key for local development.
# On Cloud Run, Application Default Credentials are used automatically.
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Optional: Flask backend port and the URL the frontend uses to reach it.
# Defaults to 5000. On macOS, port 5000 is taken by the AirPlay Receiver,
# so set these to 5001 for local development.
BACKEND_PORT=5000
BACKEND_URL=http://127.0.0.1:5000
